generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Nasabah {
  id                Int              @id @default(autoincrement())
  nama              String
  nik               String           @unique
  alamat            String?
  telepon           String?
  statusPernikahan  StatusPernikahan @default(BELUM_NIKAH)
  namaPasangan      String?
  agunans           Agunan[]
  registrasis       Registrasi[]
  createdAt         DateTime         @default(now())
}

enum StatusPernikahan {
  BELUM_NIKAH
  MENIKAH
  JANDA
  DUDA
}

model Registrasi {
  id            Int              @id @default(autoincrement())
  kodeRegister  String           @unique
  nomorRekening String?
  nasabah       Nasabah          @relation(fields: [nasabahId], references: [id])
  nasabahId     Int
  status        RegistrasiStatus @default(AKTIF)
  agunans       Agunan[]
  createdAt     DateTime         @default(now())
}

enum RegistrasiStatus {
  AKTIF
  LUNAS
}

model User {
  id                 Int      @id @default(autoincrement())
  nama               String
  username           String   @unique
  passwordHash       String
  role               UserRole
  status             UserStatus @default(PENDING)
  createdAt          DateTime @default(now())
  pengajuanDiajukan  PengajuanKeluar[] @relation("PengajuanDiajukan")
  stepDisetujui      PengajuanStep[]   @relation("StepDisetujui")
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

model Agunan {
  id                  Int         @id @default(autoincrement())
  kodeRegister        String
  registrasi          Registrasi  @relation(fields: [registrasiId], references: [id])
  registrasiId        Int
  jenis               AgunanJenis
  deskripsi           String?
  status              AgunanStatus @default(DI_BRANKAS)
  nasabah             Nasabah     @relation(fields: [nasabahId], references: [id])
  nasabahId           Int
  stockOpnames        StockOpname[]
  beritaAcaras        BeritaAcara[]
  beritaAcaraTransfers BeritaAcaraTransfer[]
  beritaAcaraPencairans BeritaAcaraPencairan[]
  pengajuanKeluar     PengajuanKeluar[]
  tanggalKeluarBrankas DateTime?
  tujuan              String?
  warningPesan        String?

  jenisKendaraan      String?
  nomorPolisi         String?
  namaPemilik         String?
  merk                String?
  tipeKendaraan       String?
  warna               String?
  tahunPembuatan      String?
  noRangka            String?
  noMesin             String?
  nomorBPKB           String?
  her5Reminder        DateTime?
  statusHER           String?

  nomorSHM            String?
  namaPemilikSHM      String?
  lokasiTanah         String?
  luasTanah           Float?

  nomorSK             String?
  namaPemilikSK       String?
  dinasDesa           String?

  beratEmas           Float?
  karatEmas           String?
  taksiranHarga       Float?

  nomorCovernote      String?
  tanggalTerbitCovernote DateTime?
  nomorAJB            String?
  atasNamaSertifikasi String?
  letakTanahSertifikasi String?
  luasSertifikasi     Float?
  perkiraanJadiSHM    DateTime?

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

enum AgunanJenis {
  BPKB
  SHM_AJB
  SK
  EMAS
  DEPOSITO
  PROSES_SERTIFIKASI
  LAINNYA
}

enum AgunanStatus {
  DI_BRANKAS
  PROSES_KELUAR
  HER_5_TAHUNAN
  PROSES_SERTIFIKASI
  TRANSFER_CABANG
  PENCAIRAN_ULANG
  DISERAHKAN
  KEMBALI
}

model PengajuanKeluar {
  id              Int              @id @default(autoincrement())
  agunan          Agunan           @relation(fields: [agunanId], references: [id])
  agunanId        Int
  jenisPengajuan  PengajuanJenis
  diajukanOleh    User             @relation("PengajuanDiajukan", fields: [diajukanOlehId], references: [id])
  diajukanOlehId  Int
  status          PengajuanStatus  @default(MENUNGGU)
  catatan         String?
  steps           PengajuanStep[]
  beritaAcaras    BeritaAcara[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum PengajuanJenis {
  LUNAS_LANGSUNG
  LUNAS_TRANSFER_PUSAT_KE_CABANG
  LUNAS_TRANSFER_CABANG_KE_CABANG
  PENCAIRAN_ULANG
  HER_5_TAHUN
  SERTIFIKASI
}

enum PengajuanStatus {
  MENUNGGU
  DISETUJUI
  DITOLAK
  SELESAI
}

model PengajuanStep {
  id              Int              @id @default(autoincrement())
  pengajuan       PengajuanKeluar  @relation(fields: [pengajuanId], references: [id])
  pengajuanId     Int
  urutan          Int
  rolesDiizinkan  String
  modeApproval    String           @default("OR")
  status          StepStatus       @default(MENUNGGU)
  disetujuiOleh   User?            @relation("StepDisetujui", fields: [disetujuiOlehId], references: [id])
  disetujuiOlehId Int?
  catatan         String?
  updatedAt       DateTime         @updatedAt
}

enum StepStatus {
  MENUNGGU
  DISETUJUI
  DILEWATI
}

model BeritaAcara {
  id              Int              @id @default(autoincrement())
  jenisBerita     String?          @default("SERAH_TERIMA_NASABAH")
  agunan          Agunan           @relation(fields: [agunanId], references: [id])
  agunanId        Int
  pengajuan       PengajuanKeluar? @relation(fields: [pengajuanId], references: [id])
  pengajuanId     Int?
  nomorDokumen    String           @unique
  nomorRegister   String
  namaNasabah     String
  alamat          String?
  nomorRekening   String?
  tanggalLunas    DateTime?
  jenisAgunan     String
  photoDataUrl    String?
  yangMenyerahkan String?
  menyetujui      String?
  yangMenerima    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  ttdAdmKredit        String?
  ttdYangMenyerahkan  String?
  ttdYangMenerima     String?
  ttdMengetahui       String?
  ttdAdmKreditImg       String?
  ttdYangMenyerahkanImg String?
  ttdYangMenerimaImg    String?
  ttdMengetahuiImg      String?
}

model BeritaAcaraTransfer {
  id                    Int      @id @default(autoincrement())
  agunan                Agunan   @relation(fields: [agunanId], references: [id])
  agunanId              Int
  nomorDokumen          String   @unique
  nomorRegister         String
  namaNasabah           String
  nomorRekening         String?
  tanggalLunas          DateTime?
  cabangAsal            String?
  cabangTujuan          String?
  namaPihakPertama      String?
  jabatanPihakPertama   String?
  ttdPihakPertamaImg    String?
  namaPihakKedua        String?
  jabatanPihakKedua     String?
  ttdPihakKeduaImg      String?
  namaMengetahui        String?
  jabatanMengetahui     String?
  ttdMengetahuiImg      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model BeritaAcaraPencairan {
  id                    Int      @id @default(autoincrement())
  agunan                Agunan   @relation(fields: [agunanId], references: [id])
  agunanId              Int
  nomorDokumen          String   @unique
  nomorRegister         String
  namaNasabah           String
  nomorRekening         String?
  tanggalPencairan      DateTime?
  keteranganPencairan   String?
  namaPihakPertama      String?
  jabatanPihakPertama   String?
  ttdPihakPertamaImg    String?
  namaPihakKedua        String?
  jabatanPihakKedua     String?
  ttdPihakKeduaImg      String?
  namaMengetahui        String?
  jabatanMengetahui     String?
  ttdMengetahuiImg      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model StockOpname {
  id                 Int                     @id @default(autoincrement())
  agunan             Agunan?                 @relation(fields: [agunanId], references: [id])
  agunanId           Int?
  pelaksana          StockOpnamePelaksana
  tanggal            DateTime
  hasilTemuan        String
  rekomendasi        String
  tindakLanjut       StockOpnameTindakLanjut
  statusTindakLanjut StockOpnameStatus      @default(BELUM_DITINDAKLANJUTI)
  targetSelesai      DateTime?
  catatan            String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
}

model AuditLog {
  id                 Int      @id @default(autoincrement())
  agunanId           Int?
  agunanKodeRegister String?
  action             String
  actor              String
  details            String?
  createdAt          DateTime @default(now())
}

enum StockOpnamePelaksana {
  SPI
  OJK
}

enum StockOpnameTindakLanjut {
  PERBAIKAN_ADMINISTRASI
  PENGAMANAN_ULANG
  PELAPORAN_MANAGEMENT
  PEMANTAUAN
  LAINNYA
}

enum StockOpnameStatus {
  BELUM_DITINDAKLANJUTI
  DALAM_PROSES
  SELESAI
}

enum UserRole {
  SUPERADMIN
  ADM_KREDIT_PUSAT
  ADM_KREDIT_CABANG
  KEPALA_KAS
  KASUBAG_PUSAT
  KASUBAG_CABANG
  KABAG_OPERASIONAL
  PIMPINAN_CABANG
  DIREKTUR
}